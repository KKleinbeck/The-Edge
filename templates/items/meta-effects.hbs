<section
  class="tab {{tabs.effects.cssClass}} meta-effects"
  data-group="primary"
  data-tab="effects"
  style="overflow-y: auto; overflow-x: hidden"
>
  <a title="{{ itemName 'Create' }}" data-action="createModifier"
    style="display: flex; width: 100%; justify-content: end; align-items: end; gap: 10px; padding-bottom: 10px;">
    {{ itemName "Add" }}<i class="fas fa-plus"></i>
  </a>
  {{#each item.system.effects as |effect|}}
    <div class="item-columned-page" style="align-items: center; padding-left: 10px;">
      <select class="selection-box modifier-hook" data-index="{{@index}}" data-entry="group" style="padding: 0 2px 0 2px;">
        {{#each ../definedEffects as |name group|}}
          <option value="{{group}}" {{#if (checkEqual effect.group group)}}selected{{/if}}>{{genName group}}</option>
        {{/each}}
      </select>
      <select class="selection-box modifier-hook" data-index="{{@index}}" data-entry="field"
        style="padding: 0 2px 0 px; min-width: 50%; text-overflow: ellipsis;">
        {{#each (getEntry ../definedEffects effect.group) as |target field|}}
          <option value="{{field}}" {{#if (checkEqual effect.field field)}}selected{{/if}}>{{effectRequirementName field effect.group}}</option>
        {{/each}}
      </select>
      <input class="modifier-hook" data-index="{{@index}}" type="number" data-entry="value" value="{{effect.value}}" style="width: 45px; text-align: right;"/>
      <a data-action="deleteModifier" data-index="{{@index}}" title="{{ itemName 'delete' }}"><i class="fas fa-trash"></i></a>
    </div>
  {{/each}}
</section>