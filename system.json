{
  "id": "the_edge",
  "title": "The Edge",
  "url": "https://github.com/KKleinbeck/The-Edge",
  "description": "A Sci-Fi centric rule system, heavily inspired by the DSA ruleset.",
  "license": "LICENSE.txt",
  "authors": [
    {
      "name": "Kevin Kleinbeck",
      "flags": {}
    }
  ],
  "esmodules": [
    "built/the_edge.js"
  ],
  "styles": [
    "styles/simple.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json",
      "flags": {}
    }
  ],
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": ["biography", "notes"]
      },
      "Store": {}
    },
    "Item": {
      "Advantage": {"htmlFields": ["description"]},
      "Ammunition": {"htmlFields": ["description"]},
      "Armour": {"htmlFields": ["description"]},
      "Consumables": {"htmlFields": ["description"]},
      "Combatskill": {"htmlFields": ["description"]},
      "Disadvantage": {"htmlFields": ["description"]},
      "Gear": {"htmlFields": ["description"]},
      "Languageskill": {"htmlFields": ["description"]},
      "Medicalskill": {"htmlFields": ["description"]},
      "Skill": {"htmlFields": ["description"]},
      "Weapon": {"htmlFields": ["description"]}
    }
  },
  "grid": {
    "distance": 1,
    "units": "m"
  },
  "socket": true,
  "primaryTokenAttribute": "health.value",
  "secondaryTokenAttribute": "heartRate.value",
  "version": "v0.14.1",
  "manifest": "https://raw.githubusercontent.com/KKleinbeck/The-Edge/master/system.json",
  "download": "https://github.com/KKleinbeck/The-Edge/archive/refs/tags/v0.14.1.zip"
}